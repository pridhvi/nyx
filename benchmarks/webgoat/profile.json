{
  "id": "webgoat",
  "name": "OWASP WebGoat",
  "target_env": "NYX_BENCHMARK_WEBGOAT_URL",
  "default_url": "http://127.0.0.1:18088/WebGoat",
  "docker": {
    "container_name": "nyx-benchmark-webgoat",
    "image": "webgoat/webgoat",
    "host_port_env": "NYX_BENCHMARK_WEBGOAT_PORT",
    "default_host_port": 18088,
    "container_port": 8080,
    "webwolf_host_port_env": "NYX_BENCHMARK_WEBWOLF_PORT",
    "webwolf_default_host_port": 19090,
    "webwolf_container_port": 9090
  },
  "auth": {
    "type": "form",
    "login_url": "/WebGoat/login",
    "username": "nyxbench",
    "password": "Nyx12345",
    "username_field": "username",
    "password_field": "password",
    "validation_url": "/WebGoat/service/lessonmenu.mvc",
    "validation_contains": "SqlInjection"
  },
  "setup": {
    "baseline_only": false,
    "register_user": true,
    "source_tag": "v2025.3",
    "minimum_covered": 14,
    "allow_failed_tools": false
  },
  "safe_active_checks": {
    "allow_dom_xss": true,
    "allow_stored_xss": true,
    "intentionally_vulnerable": true,
    "non_production": true
  },
  "notes": [
    "WebGoat uses an app-root path and path-scoped JSESSIONID cookie; auth setup registers the deterministic benchmark user and validates the lesson menu.",
    "The accepted gate is category-level: authenticated dynamic lesson routes are combined with a pinned v2025.3 Java source audit. Core scanner adapters must not hardcode WebGoat lesson names or challenge solutions."
  ]
}
