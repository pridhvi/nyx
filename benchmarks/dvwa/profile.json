{
  "id": "dvwa",
  "name": "Damn Vulnerable Web Application",
  "target_env": "NYX_BENCHMARK_DVWA_URL",
  "default_url": "http://127.0.0.1:18080",
  "docker": {
    "container_name": "nyx-benchmark-dvwa",
    "image": "vulnerables/web-dvwa",
    "host_port_env": "NYX_BENCHMARK_DVWA_PORT",
    "default_host_port": 18080,
    "container_port": 80
  },
  "auth": {
    "type": "form",
    "login_url": "/login.php",
    "username": "admin",
    "password": "password",
    "username_field": "username",
    "password_field": "password",
    "csrf_field": "user_token",
    "extra_fields": {
      "Login": "Login"
    },
    "validation_url": "/index.php",
    "validation_contains": "Logout",
    "cookie_names": ["PHPSESSID", "security"],
    "post_login_setup": [
      {
        "method": "POST",
        "path": "/security.php",
        "csrf_field": "user_token",
        "form": {
          "security": "low",
          "seclev_submit": "Submit"
        }
      }
    ]
  },
  "setup": {
    "validate_login": true,
    "security_level": "low",
    "fail_if_security_level_mismatch": true
  },
  "safe_active_checks": {
    "allow_credential_validation": true,
    "allow_command_injection": true,
    "allow_stored_xss": true,
    "credential_max_attempts": 1,
    "credential_candidates": [
      {
        "username": "admin",
        "password": "password"
      }
    ],
    "credential_success_contains": [
      "Welcome to the password protected area"
    ],
    "intentionally_vulnerable": true,
    "non_production": true
  },
  "notes": [
    "Auth, CSRF extraction, and security-level setup are benchmark profile data.",
    "Core scanner adapters must not hardcode DVWA route or cookie behavior."
  ]
}
