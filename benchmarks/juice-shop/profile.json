{
  "id": "juice-shop",
  "name": "OWASP Juice Shop",
  "target_env": "NYX_BENCHMARK_JUICE_URL",
  "default_url": "http://127.0.0.1:13000",
  "docker": {
    "container_name": "nyx-benchmark-juice-shop",
    "image": "bkimminich/juice-shop",
    "host_port_env": "NYX_BENCHMARK_JUICE_PORT",
    "default_host_port": 13000,
    "container_port": 3000,
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=8192"
    }
  },
  "auth": {
    "type": "json_login",
    "register_url": "/api/Users/",
    "login_url": "/rest/user/login",
    "username": "nyx-benchmark@example.test",
    "password": "NyxBenchmark!12345",
    "token_json_path": "authentication.token",
    "auth_header": "Authorization",
    "auth_header_prefix": "Bearer "
  },
  "setup": {
    "register_user": true,
    "security_question_id": 1,
    "security_question": "Your eldest siblings middle name?",
    "security_answer": "nyx",
    "login_preflight": true
  },
  "safe_active_checks": {
    "allow_dom_xss": true,
    "dom_xss_wait_ms": 2500,
    "intentionally_vulnerable": true,
    "non_production": true
  },
  "notes": [
    "Juice Shop benchmark setup may create or reuse a benchmark user.",
    "Core scanner adapters must not hardcode Juice Shop challenge names or routes."
  ]
}
